<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.web>
    <!-- FIXED, KNOWN machineKey for deterministic, reproducible MAC ground-truth.
         The validation algorithm is overridden per-run from code via
         MachineKeySection so we can capture both SHA1 and HMACSHA256.
         Keys below are the hard-coded canonical values used by the fixtures;
         they are duplicated verbatim in Program.cs and in the manifest. -->
    <machineKey
      validationKey="1234567890ABCDEF1234567890ABCDEF1234567890ABCDEF1234567890ABCDEF1234567890ABCDEF1234567890ABCDEF1234567890ABCDEF1234567890ABCDEF"
      decryptionKey="1234567890ABCDEF1234567890ABCDEF1234567890ABCDEF"
      validation="SHA1"
      decryption="AES" />
  </system.web>
</configuration>
